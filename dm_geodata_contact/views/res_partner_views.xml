<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_partner_form_geodata" model="ir.ui.view">
        <field name="name">res.partner.form.geodata</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Приховані контрольні поля (стабільний xpath за іменами) -->
            <xpath expr="//div[hasclass('o_address_format')]" position="before">
                <field name="has_geodata_credential" invisible="1"/>
                <field name="geodata_autocomplete_active" invisible="1"/>
                <field name="geodata_address_id" invisible="1"/>
                <field name="geodata_city_moniker" invisible="1"/>
                <field name="geodata_street_moniker" invisible="1"/>
                <field name="geodata_show_manual_hint" invisible="1"/>
                <field name="geodata_city_verified" invisible="1"/>
                <field name="geodata_street_verified" invisible="1"/>
                <field name="country_code" invisible="1"/>
            </xpath>

            <!-- Детермінований порядок полів адреси: Місто, Область, Індекс,
                 Країна (через flex order у SCSS). -->
            <xpath expr="//div[hasclass('o_address_format')]" position="attributes">
                <attribute name="class" add="o_geodata_address_grid" separator=" "/>
            </xpath>

            <!-- Вбудована автопідказка на місті -->
            <xpath expr="//field[@name='city']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_cities',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_city_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <!-- Вбудована автопідказка на вулиці -->
            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_streets',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_street_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <!-- Район + Громада (заповнюються з API за шаблонами block_format_*). -->
            <xpath expr="//div[hasclass('o_address_format')]//field[@name='state_id']" position="after">
                <field name="area" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
                <field name="hromada" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
            </xpath>

            <!-- Сторінка «Інформація про адресу» -->
            <xpath expr="//notebook" position="inside">
                <page name="geodata_page" string="Address Information">
                    <div class="alert alert-warning" role="alert"
                         invisible="has_geodata_credential">
                        <strong>Geodata.online not configured</strong>
                        <br/>
                        Configure Geodata API credentials in Settings to enable
                        address autocomplete.
                    </div>
                    <div class="alert alert-info" role="alert"
                         invisible="country_code == 'UA' or not has_geodata_credential">
                        <strong>To enable address suggestions, select country: Ukraine</strong>
                    </div>
                    <!-- Перший рядок (повна адреса) як заголовок групи: жирний,
                         капс, підкреслений, на всю ширину. -->
                    <div class="fw-bold text-uppercase w-100 mb-2 pb-2 border-bottom"
                         invisible="not geodata_address_id">
                        <field name="geodata_address_display" nolabel="1" readonly="1"/>
                    </div>
                    <!-- Деталі адреси: дві конфігуровані колонки (шаблони з Налаштувань). -->
                    <group invisible="not geodata_address_id" class="o_geodata_details_row">
                        <group>
                            <field name="geodata_details_col1" nolabel="1" readonly="1"/>
                        </group>
                        <group>
                            <field name="geodata_details_col2" nolabel="1" readonly="1"/>
                        </group>
                    </group>
                    <!-- Адреси: документи / конверти у дві колонки. -->
                    <group invisible="not has_geodata_credential">
                        <group string="Addresses for Documents" name="contract_addresses">
                            <field name="geodata_address_full_ua"
                                   string="UA" widget="CopyClipboardChar"/>
                            <field name="geodata_address_full_en"
                                   string="EN" widget="CopyClipboardChar"/>
                        </group>
                        <group string="Addresses for Envelopes" name="letter_addresses">
                            <field name="geodata_address_letter_ua"
                                   string="UA" widget="CopyClipboardChar"/>
                            <field name="geodata_address_letter_en"
                                   string="EN" widget="CopyClipboardChar"/>
                        </group>
                    </group>
                    <div class="text-muted mt-3" invisible="not has_geodata_credential">
                        <a href="https://geodata.online" target="_blank"
                           class="text-primary text-decoration-underline">GEODATA.online - address normalization and validation service for Ukraine</a>
                    </div>
                </page>
            </xpath>

            <!-- Вбудована форма дочірньої адреси (діалог «Контакти та адреси»:
                 Доставка / Рахунок / Інше). Обмежено власним адресним блоком форми
                 child_ids, щоб не зачіпати основну адресу партнера. -->
            <xpath expr="//field[@name='child_ids']//div[@name='div_address']" position="before">
                <field name="has_geodata_credential" invisible="1"/>
                <field name="geodata_autocomplete_active" invisible="1"/>
                <field name="geodata_address_id" invisible="1"/>
                <field name="geodata_city_moniker" invisible="1"/>
                <field name="geodata_street_moniker" invisible="1"/>
                <field name="geodata_show_manual_hint" invisible="1"/>
                <field name="geodata_city_verified" invisible="1"/>
                <field name="geodata_street_verified" invisible="1"/>
                <field name="country_code" invisible="1"/>
            </xpath>

            <xpath expr="//field[@name='child_ids']//div[@name='div_address']//field[@name='city']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_cities',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_city_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <xpath expr="//field[@name='child_ids']//div[@name='div_address']//field[@name='street']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_streets',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_street_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <xpath expr="//field[@name='child_ids']//div[@name='div_address']//field[@name='state_id']" position="after">
                <field name="area" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
                <field name="hromada" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
            </xpath>

        </field>
    </record>

    <!-- Окрема форма адреси (використовується потоками, що відкривають адресу
         партнера напряму). Компактна форма без notebook. -->
    <record id="view_partner_address_form_geodata" model="ir.ui.view">
        <field name="name">res.partner.form.address.geodata</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_address_form"/>
        <field name="arch" type="xml">

            <xpath expr="//div[hasclass('o_address_format')]" position="before">
                <field name="has_geodata_credential" invisible="1"/>
                <field name="geodata_autocomplete_active" invisible="1"/>
                <field name="geodata_address_id" invisible="1"/>
                <field name="geodata_city_moniker" invisible="1"/>
                <field name="geodata_street_moniker" invisible="1"/>
                <field name="geodata_show_manual_hint" invisible="1"/>
                <field name="geodata_city_verified" invisible="1"/>
                <field name="geodata_street_verified" invisible="1"/>
                <field name="country_code" invisible="1"/>
            </xpath>

            <xpath expr="//div[hasclass('o_address_format')]" position="attributes">
                <attribute name="class" add="o_geodata_address_grid" separator=" "/>
            </xpath>

            <xpath expr="//field[@name='city']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_cities',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_city_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_streets',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_street_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <xpath expr="//div[hasclass('o_address_format')]//field[@name='state_id']" position="after">
                <field name="area" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
                <field name="hromada" class="o_geodata_addr_col" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
            </xpath>

        </field>
    </record>
</odoo>
