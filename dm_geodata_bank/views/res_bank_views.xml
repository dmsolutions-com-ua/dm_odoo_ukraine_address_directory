<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="view_res_bank_form_geodata" model="ir.ui.view">
        <field name="name">res.bank.form.geodata</field>
        <field name="model">res.bank</field>
        <field name="inherit_id" ref="base.view_res_bank_form"/>
        <field name="arch" type="xml">

            <!-- Приховані контрольні поля, прив'язані до поля city. -->
            <xpath expr="//field[@name='city']" position="before">
                <field name="has_geodata_credential" invisible="1"/>
                <field name="geodata_autocomplete_active" invisible="1"/>
                <field name="geodata_address_id" invisible="1"/>
                <field name="geodata_city_moniker" invisible="1"/>
                <field name="geodata_street_moniker" invisible="1"/>
                <field name="geodata_show_manual_hint" invisible="1"/>
                <field name="geodata_city_verified" invisible="1"/>
                <field name="geodata_street_verified" invisible="1"/>
                <field name="geodata_zip_verified" invisible="1"/>
                <field name="country_code" invisible="1"/>
            </xpath>

            <!-- Вбудована автопідказка на місті -->
            <xpath expr="//field[@name='city']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_cities',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_city_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <!-- Вбудована автопідказка на вулиці -->
            <xpath expr="//field[@name='street']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'source_method': 'geodata_autocomplete_streets',
                    'on_select_method': 'apply_address',
                    'verified_field': 'geodata_street_verified',
                    'hint_field': 'geodata_show_manual_hint',
                    'min_chars': 3
                }</attribute>
            </xpath>

            <!-- Індекс: лише індикатор «введено вручну» (без autocomplete). -->
            <xpath expr="//field[@name='zip']" position="attributes">
                <attribute name="widget">geodata_autocomplete</attribute>
                <attribute name="options">{
                    'verified_field': 'geodata_zip_verified',
                    'hint_field': 'geodata_show_manual_hint'
                }</attribute>
            </xpath>

            <!-- Район + Громада (з API за шаблонами block_format_*). -->
            <xpath expr="//field[@name='state']" position="after">
                <field name="area" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
                <field name="hromada" readonly="1" force_save="1"
                       invisible="country_code != 'UA'"/>
            </xpath>

            <!-- Деталі/документні адреси — лише на картці контакту. Тут лишаємо
                 тільки інлайн-автопідказку міста/вулиці + Район/Громада. -->

        </field>
    </record>
</odoo>
