<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <record id="geodata_api_credential_view_form" model="ir.ui.view">
        <field name="name">dm.geodata.api.credential.form</field>
        <field name="model">dm.geodata.api.credential</field>
        <field name="arch" type="xml">
            <form string="Geodata.online API Credential">
                <header>
                    <button name="action_test_connection" type="object"
                            string="Test Connection" class="btn-primary" icon="fa-plug"/>
                    <button name="action_health_check" type="object"
                            string="Check Now" class="btn-secondary" icon="fa-heartbeat"/>
                    <button name="action_sync_ukraine_states" type="object"
                            string="Sync Ukraine States" class="btn-secondary"
                            icon="fa-refresh"
                            confirm="Synchronize Ukraine states with reference data?"/>
                    <field name="health_status" widget="statusbar"/>
                </header>
                <sheet>
                    <field name="update_available" invisible="1"/>
                    <div class="alert alert-warning" role="alert"
                         invisible="not update_available">
                        <button name="action_dismiss_update" type="object"
                                string="Dismiss" class="btn-link float-end"/>
                        Доступна новіша версія конектора:
                        <strong><field name="latest_version" nolabel="1"
                                       class="oe_inline"/></strong>.
                        Оновіть на
                        <a href="https://apps.odoo.com/apps/modules/19.0/dm_geodata_connector"
                           target="_blank">сторінці Apps Store</a>.
                    </div>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="api_url"/>
                            <field name="store_english"/>
                        </group>
                    </group>
                    <group string="Status" col="4">
                        <field name="last_balance"/>
                        <field name="health_last_check"/>
                        <field name="health_message" colspan="4" nolabel="0"/>
                    </group>
                    <notebook>
                        <page string="Authentication" name="auth">
                            <group>
                                <field name="api_username" autocomplete="off"/>
                                <field name="api_password" password="True" autocomplete="off"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                Register at
                                <a href="https://geodata.online/" target="_blank">geodata.online</a>
                                and enter your account email and password. The access
                                token is stored securely and refreshed automatically.
                            </div>
                        </page>
                        <page string="Autocomplete" name="autocomplete">
                            <group>
                                <field name="min_chars"/>
                                <field name="debounce_ms"/>
                                <field name="show_manual_hint"/>
                            </group>
                        </page>
                        <page string="Address Templates" name="formats">
                            <group string="Document / envelope address">
                                <field name="address_format_display"
                                       placeholder="{country}, {Index_}, {Region} ({RegionOld}), {CityFull}, ({CityDistrict} район міста), {StreetFull}, {HouseNum}{HouseNumAdd}"/>
                                <field name="address_format_document"
                                       placeholder="{country}, {Index_}, {Region}, {SettlementType} {City}, {StrType} {Street}, {HouseNum}{HouseNumAdd}"/>
                                <field name="address_format_letter"
                                       placeholder="{StrType} {Street}, {HouseNum}{HouseNumAdd}, {SettlementType} {City}, {Region}, {Index_}"/>
                            </group>
                            <group string="Address block fields (filled from API)">
                                <field name="block_format_city"
                                       placeholder="{CityFull}"/>
                                <field name="block_format_street"
                                       placeholder="{StreetFull}, {HouseNum}{HouseNumAdd}"/>
                                <field name="block_format_street2"
                                       placeholder=""/>
                                <field name="block_format_area"
                                       placeholder="{Area} ({AreaOld})"/>
                                <field name="block_format_hromada"
                                       placeholder="{HromadaFull}"/>
                            </group>
                            <group string="Address details columns (contact tab)">
                                <field name="details_format_col1"/>
                                <field name="details_format_col2"/>
                            </group>
                            <div class="alert alert-info" role="alert">
                                <h6 class="mb-2"><strong>Як працюють шаблони</strong></h6>
                                <ul class="mb-2">
                                    <li>Імена плейсхолдерів = імена полів API; значення
                                        підставляються «як є».</li>
                                    <li>Порожнє поле прибирається разом із сусіднім
                                        роздільником: «{A}, {B}» за порожнього B → «A».</li>
                                    <li>Щоб <strong>прибрати цілий фрагмент</strong>, коли поле
                                        порожнє — обгорніть його в дужки
                                        <strong>( ) [ ] « »</strong>: фрагмент із
                                        плейсхолдером(ами) зникає повністю (разом із текстом),
                                        якщо всі вони порожні. Напр. «(на дату {updated})»
                                        зникне за порожнього {updated}; «({CityOld})» — за
                                        порожньої старої назви. Фрагмент без плейсхолдерів
                                        лишається.</li>
                                    <li>Шаблон може бути багаторядковим: рядок, де всі
                                        плейсхолдери порожні, ховається.</li>
                                    <li>У колонках «Деталі адреси» дозволено HTML
                                        (таблиці, посилання); значення з API екрануються,
                                        бари URL стають клікабельними.</li>
                                </ul>
                                <table class="table table-sm table-bordered">
                                    <thead><tr><th>Плейсхолдер</th><th>Призначення</th></tr></thead>
                                    <tbody>
                                        <tr><td>{country}</td><td>Країна (УКРАЇНА / Ukraine)</td></tr>
                                        <tr><td>{Index_}</td><td>Поштовий індекс</td></tr>
                                        <tr><td>{Region} / {RegionOld}</td><td>Область / стара назва</td></tr>
                                        <tr><td>{Area} / {AreaOld}</td><td>Район / стара назва</td></tr>
                                        <tr><td>{Hromada} / {HromadaOld}</td><td>Громада (без «гр.») / стара</td></tr>
                                        <tr><td><strong>{HromadaFull}</strong></td><td>Розумно: «Сумська гр. (Стара гр.)»; порожньо, якщо громади немає</td></tr>
                                        <tr><td>{SettlementType} / {SettlementTypeOld}</td><td>Тип населеного пункту / старий</td></tr>
                                        <tr><td>{City} / {CityOld}</td><td>Населений пункт / стара назва</td></tr>
                                        <tr><td><strong>{CityFull}</strong></td><td>Розумно: «село Іванівка (селище Калинівка)»; за зміни лише типу — «село (селище) Іванівка»</td></tr>
                                        <tr><td>{Suburb} / {SuburbOld}</td><td>Передмістя / старе</td></tr>
                                        <tr><td>{CityDistrict}</td><td>Район міста</td></tr>
                                        <tr><td>{StrType} / {StrTypeOld}</td><td>Тип вулиці / старий</td></tr>
                                        <tr><td>{Street} / {StreetOld}</td><td>Назва вулиці / стара</td></tr>
                                        <tr><td><strong>{StreetFull}</strong></td><td>Розумно: вулиця з типом і старою назвою</td></tr>
                                        <tr><td>{HouseNum} / {HouseNumAdd}</td><td>Номер будинку / літера-корпус</td></tr>
                                        <tr><td>{KATO}</td><td>Код КАТОТТГ</td></tr>
                                        <tr><td>{KOATUU}</td><td>Код КОАТУУ</td></tr>
                                        <tr><td>{PhoneCode}</td><td>Телефонний код</td></tr>
                                        <tr><td>{TerrStatus}</td><td>Статус території (ТОТ)</td></tr>
                                        <tr><td>{IsOCentre} / {IsRCentre}</td><td>Обласний / районний центр (Так)</td></tr>
                                        <tr><td>{Lat_} / {Long_}</td><td>Координати будинку</td></tr>
                                        <tr><td>{Lat_S} / {Long_S}</td><td>Координати населеного пункту</td></tr>
                                        <tr><td>{MetroStation} / {MetroLine} / {MetroDistance}</td><td>Метро: станція / лінія / відстань</td></tr>
                                        <tr><td>{CityString} / {StreetString} / {HouseString}</td><td>Готові рядки від API</td></tr>
                                        <tr><td>{updated}</td><td>Дата оновлення запису адреси</td></tr>
                                        <tr><td>{name} / {partner_name}</td><td>Назва / повна назва контакту</td></tr>
                                        <tr><td>{company_name}</td><td>Компанія контакту</td></tr>
                                        <tr><td>{vat} / {ref}</td><td>ЄДРПОУ-ІПН / внутрішній код</td></tr>
                                        <tr><td>{phone} / {mobile} / {email}</td><td>Телефон / мобільний / email контакту</td></tr>
                                        <tr><td>{function} / {title}</td><td>Посада / звертання</td></tr>
                                        <tr><td>{street2}</td><td>Адресний рядок 2 (Odoo)</td></tr>
                                    </tbody>
                                </table>
                                <p class="mb-0 text-muted">Поля контакту доступні в усіх
                                    шаблонах і читаються з правами поточного користувача
                                    (обмежені поля — порожні).</p>
                            </div>
                        </page>
                        <page string="Logging" name="logging">
                            <group>
                                <field name="is_log_enabled"/>
                                <field name="log_retention_days"/>
                            </group>
                        </page>
                        <page string="Monitoring" name="monitoring">
                            <group>
                                <group string="Health">
                                    <field name="health_check_enabled"/>
                                    <field name="balance_alert_threshold"/>
                                    <field name="payment_notification_interval"/>
                                </group>
                                <group string="Updates">
                                    <field name="update_check_enabled"/>
                                    <field name="latest_version" readonly="1"/>
                                </group>
                            </group>
                            <div class="alert alert-info" role="alert">
                                The daily <strong>Geodata: health check</strong>
                                scheduled action verifies server reachability,
                                authentication and account balance. Problems are
                                written to the server log and pushed to
                                Geodata.online managers as a live notification.
                                Use <strong>Check Now</strong> to run it on demand.
                                It also compares the installed connector version with
                                the published one on GitHub (branch 19.0) and notifies
                                managers when a newer release is available — only a GET
                                of a public file, nothing about this system is sent.
                            </div>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="geodata_api_credential_view_list" model="ir.ui.view">
        <field name="name">dm.geodata.api.credential.list</field>
        <field name="model">dm.geodata.api.credential</field>
        <field name="arch" type="xml">
            <list string="Geodata.online Credentials">
                <field name="name"/>
                <field name="api_url"/>
                <field name="health_status"
                       decoration-success="health_status == 'ok'"
                       decoration-warning="health_status == 'warning'"
                       decoration-danger="health_status == 'error'"
                       decoration-muted="health_status == 'unknown'"
                       widget="badge"/>
                <field name="last_balance"/>
                <field name="active"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="geodata_api_credential_action" model="ir.actions.act_window">
        <field name="name">API Credentials</field>
        <field name="res_model">dm.geodata.api.credential</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_geodata_root" name="Geodata.online"
              parent="base.menu_administration" sequence="90"
              groups="group_geodata_manager"/>

    <menuitem id="menu_geodata_api_credential" name="API Credentials"
              parent="menu_geodata_root" action="geodata_api_credential_action"
              sequence="10"/>

</odoo>
