<?xml version="1.0" encoding="UTF-8" ?>
<odoo noupdate="1">

    <record id="cron_geodata_request_log_cleanup" model="ir.cron">
        <field name="name">Geodata: cleanup outdated request logs</field>
        <field name="model_id" ref="model_dm_geodata_request_log"/>
        <field name="state">code</field>
        <field name="code">model.cron_delete_outdated_logs()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active" eval="True"/>
    </record>

</odoo>
